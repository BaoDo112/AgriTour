{
  "family": "agritour-booking-billing",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "taskRoleArn": "REPLACE_WITH_TASK_ROLE_ARN",
  "executionRoleArn": "REPLACE_WITH_EXECUTION_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "booking-billing",
      "image": "REPLACE_WITH_ECR_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3002,
          "hostPort": 3002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "3002"
        },
        {
          "name": "DB_HOST",
          "value": "REPLACE_WITH_DB_HOST"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_USER",
          "value": "REPLACE_WITH_DB_USER"
        },
        {
          "name": "DB_PASSWORD",
          "value": "REPLACE_WITH_DB_PASSWORD"
        },
        {
          "name": "DB_NAME",
          "value": "agritour_booking"
        },
        {
          "name": "JWT_SECRET",
          "value": "REPLACE_WITH_JWT_SECRET"
        },
        {
          "name": "TOUR_FETCH_TIMEOUT_MS",
          "value": "1500"
        },
        {
          "name": "TOUR_FETCH_RETRIES",
          "value": "1"
        },
        {
          "name": "TOUR_CATALOG_PROVIDER_ORDER",
          "value": "service,request,mock"
        },
        {
          "name": "TOUR_CATALOG_FALLBACK",
          "value": "mock"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/agritour-booking-billing",
          "awslogs-region": "REPLACE_WITH_AWS_REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --no-verbose --tries=1 --spider http://localhost:3002/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      }
    }
  ]
}